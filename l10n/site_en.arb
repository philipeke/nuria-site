  "supp.form_subject": "Subject",
  "supp.founder_badge": "Product Owner",
  "supp.founder_eyebrow": "Built With Intention",
  "supp.founder_p1": "Adam is the product lead behind Nuria, a project built from personal faith, lived experience, and a clear purpose.",
  "supp.founder_p2": "He embraced Islam in adulthood at the Bosnian mosque in Gothenburg, where his reversion was guided by Imam Fuad Colic. However, his connection to Islam goes further back: he has lived closely connected to the faith since the age of 16, shaped both by personal experience and the Muslim community around him.",
  "supp.founder_p3": "With a background as a long-time entrepreneur, Adam has built and led several successful ventures. Yet Nuria stands apart from everything else he has done.",
  "supp.founder_p4": "Nuria was not created as just another app. It was built out of a real need: a need for something simpler, clean and ad-free, secure, more beautiful, and more meaningful. An app designed by a Muslim, for Muslim needs, shaped by Islam and refined together with other Muslims.",
  "supp.founder_p5": "The project has been developed alongside a close circle of fellow believers, together with his lifelong brother Philip, with whom he runs a technology studio.",
  "supp.founder_p6": "Together, they share one intention: to build something of real value for the ummah.",
  "supp.founder_quote_strong": "Nuria is the result of that intention.",
  "supp.founder_quote_text": "A focused effort to create an experience that helps Muslims stay connected to their faith, every day.",
  "supp.founder_title": "About the Product Owner",
  "supp.phone_label": "Phone",
  "supp.regno_label": "Reg. No.",
