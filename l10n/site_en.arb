  "pages.doc_sources_title": "Sources & Standards - Nuria",
  "pages.doc_sources_desc": "See where Nuria's Quran, duas, prayer tools, audio, and AI guidance are grounded, and how we approach accuracy, privacy, and care.",
  "footer.sources": "Sources",
  "sources.hero_label": "How Nuria is built",
  "sources.hero_title": "Sources & Standards",
  "sources.hero_subtitle": "Every verse, dua, prayer tool, and guidance flow in Nuria should rest on a clear foundation. This page explains where the app's core content comes from and how we think about care, privacy, and accuracy.",
  "sources.hero_stat_auth": "Verified texts",
  "sources.hero_stat_privacy": "Privacy-first design",
  "sources.hero_stat_review": "Human editorial review",
  "sources.intro_eyebrow": "A trustworthy foundation",
  "sources.intro_title": "Built on trusted Islamic references, careful product work, and privacy-conscious engineering.",
  "sources.intro_text": "Nuria combines established Islamic texts, editorial review, and on-device calculations where privacy matters. We aim to be transparent about what comes from classical sources, what reflects product guidance, and what depends on device sensors or AI.",
  "sources.principle_1_title": "Authenticity first",
  "sources.principle_1_text": "We try to keep sacred texts, supplications, and religious references anchored in established Sunni material rather than vague summaries or trend-driven rewrites.",
  "sources.principle_2_title": "Privacy by default",
  "sources.principle_2_text": "When a feature can be calculated on your device, we prefer that approach. This is especially important for prayer times, Qibla, and personal spiritual use.",
  "sources.principle_3_title": "Clarity over overclaiming",
  "sources.principle_3_text": "If something depends on AI, location, or device sensors, we say so clearly and encourage verification with trusted local scholars or mosques when precision matters.",
  "sources.card_quran_title": "Quran text and translations",
  "sources.card_quran_text": "The Arabic Quran text is based on verified Quran datasets such as Tanzil, together with established translation datasets used in trusted Islamic archives. We handle presentation changes carefully and avoid casual edits to the text itself.",
  "sources.card_dua_title": "Duas and adhkar",
  "sources.card_dua_text": "Supplications and remembrance collections are grounded in recognised works such as Hisnul Muslim and classical hadith collections including Sahih al-Bukhari, Sahih Muslim, and Sunan Abu Dawud.",
  "sources.card_prayer_title": "Prayer times and Qibla",
  "sources.card_prayer_text": "Prayer times and Qibla direction are calculated on your device using standard astronomical and geographic formulas, your location, and compass data. For mosque schedules or critical observance, always verify locally.",
  "sources.card_ai_title": "Ask Nuria and AI guidance",
  "sources.card_ai_text": "Ask Nuria is designed to respond with guidance rooted in the Quran, Hadith, and mainstream Sunni teaching. It is meant to support reflection and comfort, not to invent rulings or replace qualified scholars.",
  "sources.card_audio_title": "Recitations, audio, and talks",
  "sources.card_audio_text": "Quran recitations and selected audio are sourced from licensed, public, or otherwise rights-respecting providers, including sources such as EveryAyah where appropriate.",
  "sources.card_editorial_title": "Reflections and editorial content",
  "sources.card_editorial_text": "Daily reflections and learning content are written and reviewed with the Quran, Hadith, tafsir, Riyad as-Salihin, and other classical references as their foundation.",
  "sources.note_title": "A careful boundary",
  "sources.note_text": "Prayer times, Qibla direction, and AI answers are built to support daily practice, but they do not replace your local mosque, qualified scholars, or formal religious rulings.",
  "sources.report_title": "See something that looks wrong?",
  "sources.report_text": "If you notice a typo, source issue, broken reference, or anything that feels off, contact us. We review reports carefully and correct verified issues as quickly as we can.",
  "sources.report_link": "Contact support",
  "sources.quote_ar": "وَقُل رَّبِّ زِدْنِي عِلْمًا",
  "sources.quote_text": "\"My Lord, increase me in knowledge.\"",
  "sources.quote_ref": "Quran 20:114",
  "sources.quote_note": "We want Nuria to stay beautiful, useful, and open to correction whenever something can be made more precise."
}
